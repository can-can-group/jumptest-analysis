# MongoDB (remote or local). Copy to .env and fill in your values.
# Do not commit .env to version control.
# The API loads .env automatically when started (python-dotenv).

# Connection string (use MONGODB_URI or MONGO_URI).
# Examples:
#   Atlas:  mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net
#   Remote: mongodb://USER:PASSWORD@host:27017
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net

# Database name to use (default: jumptest)
MONGODB_DB=jumptest

# Admin: create admins via POST /admin/register with header X-Admin-Secret
ADMIN_SECRET=your-secret-here
JWT_SECRET=change-me-in-production
# JWT expiry in minutes (default 10080 = 7 days)
# JWT_EXPIRE_MINUTES=10080

# Force signal filter: low-pass cutoff in Hz before event detection (0 = disabled). E.g. 50 to reduce noise.
# FORCE_FILTER_CUTOFF_HZ=50

# Email: for POST /jump-tests/{id}/send-link (required for sending links)
# Gmail: use App Password (https://myaccount.google.com/apppasswords), not your normal password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your.email@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_FROM=your.email@gmail.com
# EMAIL_BASE_URL = public base URL for links in emails.
# Development: http://localhost:8000
# Production with gateway: https://wellbodytech.com (website embeds API viewer via iframe)
# Production standalone: https://customer-domain.com/jump-test (direct API access)
# EMAIL_BASE_URL=https://wellbodytech.com

# BASE_PATH: public URL prefix when served behind a reverse proxy.
# Must match the Nginx location path. Leave empty for standalone / development.
# Examples: /arge (wellbodytech.com/arge/), /jump-test (customer.com/jump-test/)
# BASE_PATH=/arge
