# MongoDB (remote or local). Copy to .env and fill in your values.
# Do not commit .env to version control.
# The API loads .env automatically when started (python-dotenv).

# Connection string (use MONGODB_URI or MONGO_URI).
# Examples:
#   Atlas:  mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net
#   Remote: mongodb://USER:PASSWORD@host:27017
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net

# Database name to use (default: jumptest)
MONGODB_DB=jumptest

# Admin: create admins via POST /admin/register with header X-Admin-Secret
ADMIN_SECRET=your-secret-here
JWT_SECRET=change-me-in-production
# JWT expiry in minutes (default 10080 = 7 days)
# JWT_EXPIRE_MINUTES=10080

# Email: for POST /jump-tests/{id}/send-link (required for sending links)
# Gmail: use App Password (https://myaccount.google.com/apppasswords), not your normal password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your.email@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_FROM=your.email@gmail.com
# EMAIL_BASE_URL=http://localhost:8000
# (EMAIL_BASE_URL = public URL of your API so the link in the email works; use https in production)
